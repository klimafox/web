---
layout: layouts/base.njk
---
<main class="max-w-7xl mx-auto px-4 py-8 md:py-12 space-y-10">

    {# Hero: image gallery + product info #}
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 bg-white p-4 md:p-10 rounded-3xl shadow-xl border border-gray-100">

        {# Image gallery #}
        <div class="space-y-4">
            <div class="relative rounded-2xl overflow-hidden bg-gray-50 aspect-[4/3] border border-gray-100 shadow-inner">
                <img id="mainImage" src="assets/{{ images[0] }}" alt="{{ title }}" class="w-full h-full object-contain p-4 transition duration-500">
            </div>
            <div class="grid grid-cols-4 gap-3" id="thumbnails">
                {% for img in images %}
                <img src="assets/{{ img }}" onclick="changeImage(this.src, this)"
                    class="cursor-pointer rounded-xl border-2 {% if loop.first %}border-orange-500{% else %}border-transparent hover:border-orange-500{% endif %} p-1 bg-white transition">
                {% endfor %}
            </div>
        </div>

        {# Product info #}
        <div class="flex flex-col">
            {# Contact box #}
            <div class="bg-gray-50 p-4 rounded-2xl mb-6 flex justify-between items-center border border-gray-100">
                <div>
                    <p class="text-[10px] uppercase tracking-widest text-gray-400 font-bold">Egyedi árajánlatkérés</p>
                    <a href="tel:{{ site.phoneTel }}" class="text-gray-900 font-black text-lg hover:text-orange-600">{{ site.phone }}</a>
                </div>
                <div class="text-right">
                    <p class="text-[10px] uppercase tracking-widest text-gray-400 font-bold">Email címünk</p>
                    <a href="mailto:{{ site.email }}" class="text-gray-900 font-bold text-sm hover:text-orange-600 transition">{{ site.email }}</a>
                </div>
            </div>

            <h1 class="text-4xl font-black text-gray-900 leading-tight mb-2">{{ title }}</h1>

            {# Tags #}
            <div class="flex flex-wrap gap-2 mb-6">
                {% for tag in tags %}
                <span class="
                    {% if tag.color == 'orange' %}bg-orange-100 text-orange-700{% endif %}
                    {% if tag.color == 'green' %}bg-green-100 text-green-700{% endif %}
                    {% if tag.color == 'blue' %}bg-blue-100 text-blue-700{% endif %}
                    text-xs font-bold px-3 py-1 rounded-full
                    {% if tag.italic %}italic{% endif %}
                    uppercase">{{ tag.label }}</span>
                {% endfor %}
            </div>

            {# Price box #}
            <div class="mb-8 p-6 bg-gradient-to-br from-gray-900 to-gray-800 rounded-3xl text-white shadow-xl relative overflow-hidden">
                {% if on_sale %}
                <div class="absolute -top-1 -right-1 bg-orange-500 text-white text-[10px] font-black px-6 py-2 uppercase rotate-12 shadow-lg">AKCIÓ</div>
                <p class="text-gray-400 line-through text-xl mb-1 opacity-60">{{ price_original }}</p>
                {% endif %}
                <div class="flex items-baseline gap-2">
                    <span class="text-5xl font-black text-orange-400 tracking-tighter">{{ price_sale }}</span>
                </div>
                <p class="text-[10px] text-gray-400 mt-3 uppercase tracking-widest font-bold border-t border-gray-700 pt-3">Telepítve 3 méter csőhosszig (Alapszerelés)</p>
            </div>

            {# Key parameters grid #}
            <div class="mt-2">
                <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center">
                    <span class="w-8 h-1 bg-orange-500 mr-3"></span> Főbb paraméterek
                </h3>
                <div class="grid grid-cols-2 gap-3">
                    {% for param in key_params %}
                        {% if param.h_tarifa %}
                        <div class="bg-green-100 p-3 rounded-2xl border-2 border-orange-500 shadow-md flex flex-col justify-center items-center text-center">
                            <p class="text-[10px] uppercase font-black text-green-700 mb-1 leading-none"><i class="fas fa-leaf mr-1"></i> {{ param.label }}</p>
                            <p class="text-sm font-black text-gray-900 uppercase">{{ param.value }}</p>
                        </div>
                        {% else %}
                        <div class="bg-gray-100 p-3 rounded-2xl border border-gray-200">
                            <p class="text-[10px] uppercase font-bold text-gray-500 mb-1">{{ param.label }}</p>
                            <p class="text-lg font-black text-gray-800">{{ param.value }}</p>
                        </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>

    {# Optional CTA banner (gree-comfort-pro only) #}
    {% if show_cta_banner %}
    <div class="bg-orange-500 p-6 md:p-8 rounded-3xl shadow-xl border border-orange-600 flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="flex items-center gap-4">
            <div class="bg-white/20 p-4 rounded-full">
                <i class="fas fa-comments-dollar text-white text-3xl"></i>
            </div>
            <h2 class="text-white text-xl md:text-2xl font-black leading-tight">
                Megrendeléshez, egyeztetéshez<br class="hidden md:block"> keressen minket telefonon vagy emailben!
            </h2>
        </div>
        <div class="flex flex-wrap justify-center gap-4">
            <a href="tel:{{ site.phoneTel }}" class="bg-white text-orange-600 hover:bg-gray-100 px-6 py-3 rounded-xl font-black transition shadow-lg flex items-center gap-2">
                <i class="fas fa-phone"></i> {{ site.phone }}
            </a>
            <a href="mailto:{{ site.email }}" class="bg-gray-900 text-white hover:bg-black px-6 py-3 rounded-xl font-black transition shadow-lg flex items-center gap-2">
                <i class="fas fa-envelope"></i> {{ site.email }}
            </a>
        </div>
    </div>
    {% endif %}

    {# Detailed spec table #}
    <div class="bg-white p-6 md:p-10 rounded-3xl shadow-lg border border-gray-100">
        <h3 class="text-2xl font-black text-gray-900 mb-8 uppercase tracking-tight flex items-center">
            <i class="fas fa-list-ul text-orange-500 mr-4"></i> Részletes műszaki adatok
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-12 gap-y-2 text-sm">
            {% set cols = specs | chunk3 %}
            {% for col in cols %}
            <div class="space-y-2">
                {% for item in col %}
                <div class="flex justify-between border-b border-gray-50 py-2">
                    <span class="text-gray-500">{{ item.label }}</span>
                    {% if item.value %}
                    <span class="font-bold {% if item.highlight %}text-green-600 uppercase{% endif %}">{{ item.value }}</span>
                    {% endif %}
                </div>
                {% endfor %}
            </div>
            {% endfor %}
        </div>

        {# Optional spec notes (extra boxes below the table) #}
        {% if spec_notes %}
        <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-8 text-sm">
            {% for note in spec_notes %}
            <div class="bg-gray-50 p-4 rounded-xl">
                <h4 class="font-bold text-gray-900 mb-2 uppercase text-xs">{{ note.title }}</h4>
                {% for line in note.lines %}
                <p class="text-gray-600">{{ line }}</p>
                {% endfor %}
            </div>
            {% endfor %}
        </div>
        {% endif %}

        {# Optional highlight box #}
        {% if spec_highlight %}
        <div class="mt-6 bg-orange-50 p-4 rounded-xl border-l-4 border-orange-500">
            <h4 class="font-bold text-gray-900 mb-2 text-xs uppercase">{{ spec_highlight.title }}</h4>
            <p class="text-gray-700 text-xs leading-relaxed">{{ spec_highlight.text }}</p>
        </div>
        {% endif %}
    </div>

    {# Installation info (same on all products) #}
    {% include "partials/install-info.njk" %}

    {# Optional work gallery (gree-comfort-pro only) #}
    {% if work_gallery %}
    <div class="bg-white p-6 md:p-10 rounded-3xl shadow-lg border border-gray-100">
        <h3 class="text-2xl font-black text-gray-900 mb-8 uppercase tracking-tight flex items-center">
            <i class="fas fa-camera-retro text-orange-500 mr-4"></i> Képek átadott munkáinkról
        </h3>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
            {% for img in work_gallery %}
            <div onclick="openLightbox('assets/{{ img }}')" class="relative group overflow-hidden rounded-2xl bg-gray-100 aspect-square border border-gray-100 shadow-sm cursor-pointer">
                <img src="assets/{{ img }}" class="w-full h-full object-cover transition duration-500 group-hover:scale-110">
                <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                    <i class="fas fa-search-plus text-white text-3xl"></i>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
    <div id="lightbox" class="fixed inset-0 bg-black/90 z-[100] hidden items-center justify-center p-4 cursor-pointer" onclick="closeLightbox()">
        <button class="absolute top-6 right-6 text-white text-4xl hover:text-orange-500">&times;</button>
        <img id="lightboxImg" src="" class="max-w-full max-h-[90vh] rounded-lg shadow-2xl transition-transform duration-300">
    </div>
    {% endif %}

    {# Reviews #}
    {% if reviews %}
    <div class="bg-white p-6 md:p-10 rounded-3xl shadow-lg border border-gray-100">
        <h3 class="text-2xl font-black text-gray-900 mb-8 uppercase tracking-tight flex items-center">
            <i class="fas fa-star text-orange-500 mr-4"></i> Vélemények a termékről
        </h3>
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
            <div class="lg:col-span-1 bg-gray-50 p-6 rounded-2xl border border-gray-100 h-fit text-center">
                <p class="text-5xl font-black text-gray-900 mb-2">{{ reviews.rating }}</p>
                <div class="flex justify-center text-orange-400 mb-2">
                    {% for i in range(0, 5) %}<i class="fas fa-star"></i>{% endfor %}
                </div>
                <p class="text-xs text-gray-500">{{ reviews.count }} értékelés alapján</p>
            </div>
            <div class="lg:col-span-2 space-y-8">
                <div class="border-b border-gray-100 pb-6">
                    {% for review in reviews.items %}
                    <div class="{% if not loop.first %}mt-4{% endif %}">
                        <div class="flex items-center justify-between mb-2">
                            <p class="font-bold text-gray-900 text-sm">{{ review.name }}</p>
                            <div class="text-orange-400 text-[10px]">
                                {% for i in range(0, review.stars) %}<i class="fas fa-star"></i>{% endfor %}
                            </div>
                        </div>
                        <p class="text-gray-600 text-sm italic leading-relaxed">"{{ review.text }}"</p>
                    </div>
                    {% endfor %}
                </div>
                <div class="bg-gray-900 p-6 rounded-2xl text-white shadow-xl">
                    <h4 class="font-bold mb-4 text-sm">Írja meg véleményét!</h4>
                    <form class="space-y-4">
                        <input type="text" placeholder="Az Ön neve" class="w-full bg-gray-800 border border-gray-700 text-white text-sm rounded-xl p-3 focus:outline-none focus:border-orange-500">
                        <textarea placeholder="Véleménye..." rows="2" class="w-full bg-gray-800 border border-gray-700 text-white text-sm rounded-xl p-3 focus:outline-none focus:border-orange-500"></textarea>
                        <button type="submit" class="bg-orange-500 hover:bg-orange-600 text-white font-bold py-2 px-6 rounded-xl transition duration-300">Beküldés</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    {% endif %}

</main>

<script>
    function changeImage(src, element) {
        document.getElementById('mainImage').src = src;
        var thumbs = document.getElementById('thumbnails').getElementsByTagName('img');
        for (var img of thumbs) {
            img.classList.remove('border-orange-500');
            img.classList.add('border-transparent');
        }
        element.classList.remove('border-transparent');
        element.classList.add('border-orange-500');
    }

    {% if work_gallery %}
    function openLightbox(src) {
        var lightbox = document.getElementById('lightbox');
        document.getElementById('lightboxImg').src = src;
        lightbox.classList.remove('hidden');
        lightbox.classList.add('flex');
        document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
        var lightbox = document.getElementById('lightbox');
        lightbox.classList.add('hidden');
        lightbox.classList.remove('flex');
        document.body.style.overflow = 'auto';
    }

    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') closeLightbox();
    });
    {% endif %}
</script>
